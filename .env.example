# Pi WebUI Configuration Example
HOST=0.0.0.0
PORT=8080

# Database path (default on Pi: /var/lib/piwebui/data.db, for local test you can use: data.db)
DB_PATH=/var/lib/piwebui/data.db

# Allowed systemctl services
ALLOWED_SERVICES=piwebui,nginx,ssh,bluetooth,hostapd,cron,networking,wg-quick@wg0

# File manager settings
FILE_MANAGER_ROOT=/home/pi
FILE_MANAGER_RESTRICTED=/etc/shadow,/etc/sudoers
